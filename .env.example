# ===========================================
# MiroFish Environment Configuration
# ===========================================

# ===== LLM API Configuration =====
# Supports any OpenAI-compatible API (OpenAI, Groq, DeepSeek, Alibaba Qwen, etc.)
# Note: simulation costs can be high; start with fewer than 40 rounds
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# ===== Zep Memory Graph Configuration =====
# Sign up at https://app.getzep.com/ (free tier available)
ZEP_API_KEY=your_zep_api_key_here

# ===== Optional: Boost LLM Configuration =====
# Separate LLM for high-throughput tasks (profile generation, etc.)
# Omit these entirely if not using a boost model
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=https://api.openai.com/v1
# LLM_BOOST_MODEL_NAME=gpt-4o-mini

# ===== Optional: Security & Deployment =====
# SECRET_KEY=your_random_secret_key
# CORS_ORIGINS=http://localhost:3000
# FLASK_DEBUG=False

# ===== Optional: Frontend Configuration =====
# VITE_API_BASE_URL=http://your-server:5001
# MIROFISH_FRONTEND_PORT=3000
# MIROFISH_BACKEND_URL=http://localhost:5001

# ===== Optional: Report Agent Tuning =====
# REPORT_AGENT_MAX_TOOL_CALLS=5
# REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
# REPORT_AGENT_TEMPERATURE=0.5
# REPORT_TOOL_TIMEOUT=120

# ===== Forge Signal Bridge Configuration =====
# Enable integration with Forge backtesting framework (v5.2 methodology)
# FORGE_BRIDGE_ENABLED=true
# SIGNAL_DB_URL=postgresql://forge:forge_dev@signal-db:5432/forge_signals
# SIGNAL_DB_PASSWORD=forge_dev
#
# Default target asset and timeframe for signal extraction
# FORGE_ASSET_DEFAULT=BTC-USD
# FORGE_ASSET_CLASS_DEFAULT=crypto_perps
# FORGE_TIMEFRAME_DEFAULT=4h
#
# Signal Bridge polling interval (seconds)
# POLL_INTERVAL_SECONDS=300
#
# Calibration settings (isotonic regression requires min_samples resolved predictions)
# CALIBRATION_MIN_SAMPLES=30
# CALIBRATION_PERSISTENCE_DIR=/app/data/calibration
#
# Bridge health check port
# BRIDGE_HEALTH_PORT=8080
# BRIDGE_LOG_LEVEL=INFO
