# MiroFish → Forge Signal Bridge
# Standalone service that extracts quantified trading signals from
# MiroFish swarm simulations and pushes them to the signal database.

FROM python:3.11-slim

# Install system dependencies
RUN apt-get update \
  && apt-get install -y --no-install-recommends tini libpq-dev gcc \
  && rm -rf /var/lib/apt/lists/*

# Copy uv package manager
COPY --from=ghcr.io/astral-sh/uv:0.9.26 /uv /uvx /bin/

# Create non-root user
RUN useradd --create-home --shell /bin/bash bridge

WORKDIR /app

# Install Python dependencies
COPY backend/forge_bridge/pyproject.toml ./
RUN uv pip install --system \
    "psycopg2-binary>=2.9.0" \
    "numpy>=1.24.0" \
    "scipy>=1.10.0" \
    "scikit-learn>=1.3.0" \
    "pandas>=2.0.0" \
    "openai>=1.0.0" \
    "requests>=2.31.0" \
    "pyyaml>=6.0"

# Copy bridge source
COPY backend/forge_bridge/ ./forge_bridge/

# Create data directories
RUN mkdir -p /app/data/calibration /app/signals \
  && chown -R bridge:bridge /app

USER bridge

EXPOSE 8080

# Use tini for proper signal handling
ENTRYPOINT ["tini", "--"]

CMD ["python", "-m", "forge_bridge.bridge_runner"]

HEALTHCHECK --interval=60s --timeout=10s --start-period=30s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/health')" || exit 1
